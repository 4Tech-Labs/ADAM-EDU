# ================================================================
# ADAM v8 - Environment Variables
# Copy this file to .env and fill in the real values.
# DO NOT COMMIT .env - it is in .gitignore.
# Production secrets go in Google Secret Manager, not here.
# ================================================================

# -- LLM ----------------------------------------------------------
GEMINI_API_KEY=

# -- LangSmith (optional, tracing) --------------------------------
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# -- PostgreSQL ---------------------------------------------------
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5434
DB_NAME=postgres

# DATABASE_URL - required by shared.database.Settings
# Defaults below match the repo root docker-compose.yml.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5434/postgres

# -- Connection Pooling -------------------------------------------
# Use DB_MAX_OVERFLOW=2 on Cloud Run (ephemeral instances).
# Use DB_MAX_OVERFLOW=10 locally or on persistent VMs.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# -- Deployment Environment ---------------------------------------
# development -> BackgroundTasks (local)
# production  -> Google Cloud Tasks (Cloud Run)
ENVIRONMENT=development

# -- Supabase metadata (Issue 23+ auth substrate scaffolding) -----
# Optional for the current teacher-only MVP, required once auth work starts.
SUPABASE_URL=
SUPABASE_PROJECT_REF=

# -- Google Cloud Tasks (required only when ENVIRONMENT=production)
SERVICE_URL=
CLOUD_TASKS_PROJECT=
CLOUD_TASKS_LOCATION=
CLOUD_TASKS_QUEUE=adam-authoring-jobs
CLOUD_TASKS_SERVICE_ACCOUNT=
